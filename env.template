# Tidal API Credentials
# Get these from https://developer.tidal.com
VITE_TIDAL_CLIENT_ID=your_client_id_here

# Redirect URI (must match what's registered in your Tidal app)
# For local development, use: http://localhost:5173/auth/callback
VITE_TIDAL_REDIRECT_URI=http://localhost:5173/auth/callback

# Country code (ISO 3166-1 alpha-2) - Use your Tidal account's country
# Common codes: NO (Norway), US (United States), DE (Germany), GB (United Kingdom), SE (Sweden)
# Defaults to NO (Norway, home of Tidal) if not specified
VITE_COUNTRY_CODE=NO
